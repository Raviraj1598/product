# Boutique API (.env beside `package.json`)

# Mandatory in production — admin catalog GET/PUT + timing-safe Bearer compare (`x-admin-token` header mirrors VITE_ADMIN_API_TOKEN)
ADMIN_API_SECRET=please-use-a-long-random-string

# Optional HTTP port override (default 3001)
# PORT=3001

# Comma-separated origins for browser clients (omit to mirror legacy permissive cors during local dev only)
CORS_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:5174

# Throttle brute-force checkout spikes (requests / 15m per IP-ish key)
ORDER_RATE_LIMIT_MAX=80

# GET /api/store/catalog (+ legacy /api/catalog) — shared window per client key
PUBLIC_CATALOG_RATE_LIMIT_MAX=600

# GET/PUT /api/admin/catalog combined window (per IP-ish key behind trust proxy)
ADMIN_CATALOG_RATE_LIMIT_MAX=200

# Max JSON body size for PUT /api/admin/catalog and POST /api/orders (e.g. 2mb, 512kb)
# CATALOG_JSON_LIMIT=5mb

# When the API sits behind nginx/traefik/CDN — enables correct client IPs for rate limits
# TRUST_PROXY=1

