# Boutique API — copy this file to `.env` beside package.json, then restart the API or run: npm run seed:admin

# --- Admin login (admin app at http://127.0.0.1:5174/login) ---
# First boot: empty admin_users table → API seeds from these values on startup.
ADMIN_EMAIL=admin@sanskritiethniccouture.com
ADMIN_PASSWORD=admin@123

# Optional display name for the seeded admin
# ADMIN_DISPLAY_NAME=Store admin

# Session lifetime in hours (default 168 = 7 days)
# SESSION_TTL_HOURS=168

# Optional legacy header for scripts/CI (POST /api/auth/login preferred for humans)
# ADMIN_API_SECRET=long-random-string-for-x-admin-token-header

# Optional HTTP port override (default 3001)
# PORT=3001

# Comma-separated origins for browser clients (required in production cross-origin deploys)
CORS_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:5174

# Throttle brute-force checkout spikes (requests / 15m per IP-ish key)
ORDER_RATE_LIMIT_MAX=80

# Login attempts per 15m window per IP
LOGIN_RATE_LIMIT_MAX=20

# GET /api/store/catalog (+ legacy /api/catalog)
PUBLIC_CATALOG_RATE_LIMIT_MAX=600

# GET/PUT /api/admin/catalog combined window
ADMIN_CATALOG_RATE_LIMIT_MAX=200

# Max JSON body size for PUT /api/admin/catalog and POST /api/orders
# CATALOG_JSON_LIMIT=5mb

# When the API sits behind nginx/traefik/CDN
# TRUST_PROXY=1
